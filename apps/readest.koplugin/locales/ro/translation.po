msgid "Pull readest annotations from other devices"
msgstr "Obține adnotările Readest de pe alte dispozitive"

msgid "Log in Readest Account"
msgstr "Autentificare în contul Readest"

msgid "Log out as %1"
msgstr "Deconectare de la %1"

