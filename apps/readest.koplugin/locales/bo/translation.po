msgstr ""
"Project-Id-Version: readest.koplugin\n"
"Last-Translator: Readest contributors\n"
"Language-Team: Tibetan\n"
"Language: bo\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
